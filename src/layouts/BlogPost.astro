---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagBadge from '../components/TagBadge.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<a href="/" class="back-link">&larr; Back to all posts</a>
			<article>
				<header class="article-header">
					<span class="date">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated">
								(updated <FormattedDate date={updatedDate} />)
							</span>
						)}
					</span>
					<h1>{title}</h1>
					{tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => (
								<TagBadge tag={tag} />
							))}
						</div>
					)}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.back-link {
		display: inline-block;
		margin-bottom: 2em;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.88em;
	}
	.back-link:hover {
		color: var(--text);
		text-decoration: none;
	}
	.article-header {
		margin-bottom: 2.5em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid var(--border);
	}
	.date {
		color: var(--text-muted);
		font-size: 0.82rem;
		letter-spacing: 0.02em;
	}
	.updated {
		font-style: italic;
	}
	h1 {
		margin: 0.4em 0 0.4em 0;
		font-size: 1.8em;
		line-height: 1.25;
		color: var(--text);
	}
	.tags {
		display: flex;
		gap: 0.4em;
		flex-wrap: wrap;
	}
	.prose {
		color: var(--text);
		line-height: 1.8;
	}
	.prose :global(h2) {
		margin-top: 2em;
		margin-bottom: 0.6em;
		color: var(--text);
	}
	.prose :global(h3) {
		margin-top: 1.5em;
		margin-bottom: 0.5em;
		color: var(--text);
	}
	.prose :global(a) {
		color: var(--accent);
	}
	.prose :global(a:hover) {
		color: var(--accent-hover);
	}
	.prose :global(code) {
		background-color: var(--code-bg);
	}
	.prose :global(.astro-code) {
		border: 1px solid var(--border);
	}
	:global([data-theme="dark"]) .prose :global(.astro-code) {
		background-color: var(--shiki-dark-bg, var(--code-bg)) !important;
	}
	:global([data-theme="dark"]) .prose :global(.astro-code span) {
		color: var(--shiki-dark) !important;
		font-style: var(--shiki-dark-font-style) !important;
	}
</style>
