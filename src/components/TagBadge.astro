---
interface Props {
  tag: string;
}
const { tag } = Astro.props;
---
<span class="tag-badge">{tag}</span>

<style>
  .tag-badge {
    display: inline-block;
    font-size: 0.72rem;
    padding: 2px 10px;
    border-radius: 12px;
    background: var(--tag-bg);
    color: var(--text-muted);
    transition: background-color 0.2s, color 0.2s;
  }
</style>
